{
  "name": "mcp-generative-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "verify": "node ./verify.mjs",
    "generate": "node ./generate-live.mjs",
    "stream": "node ./stream-live.mjs",
    "preview:build": "node ./preview-build.mjs",
    "preview:host": "node ./preview-host.mjs",
    "preview:stream": "node ./stream-build.mjs",
    "preview:stream:serve": "node ./stream-build.mjs && pnpm exec serve -l 5181 --no-port-switching preview/stream-dist",
    "serve:stdio": "node ./serve-stdio.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ai": "6.0.205",
    "ai-sdk-ollama": "3.8.7",
    "@ai-sdk/google": "3.0.80",
    "@ai-sdk/groq": "3.0.39",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "mountly-json-render": "workspace:*",
    "mountly-mcp": "workspace:*",
    "mountly-mcp-react": "workspace:*",
    "mountly-mcp-server": "workspace:*",
    "mountly-react": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "jsdom": "^25.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
