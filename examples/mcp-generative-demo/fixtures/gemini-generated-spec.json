{
  "root": "root",
  "state": {
    "metrics": {
      "revenue": "$1,234,567",
      "growth": "12.5%",
      "customers": "8,765"
    }
  },
  "elements": {
    "root": {
      "type": "Stack",
      "props": { "gap": 16 },
      "children": ["h", "row", "btn"]
    },
    "h": { "type": "Heading", "props": { "text": "Revenue snapshot" }, "children": [] },
    "row": { "type": "Row", "props": { "gap": 16 }, "children": ["c1", "c2", "c3"] },
    "c1": { "type": "Card", "props": {}, "children": ["s1"] },
    "s1": {
      "type": "Stat",
      "props": { "label": "Total revenue", "value": { "$state": "/metrics/revenue" }, "trend": "up", "delta": "+12.5%" },
      "children": []
    },
    "c2": { "type": "Card", "props": {}, "children": ["s2"] },
    "s2": {
      "type": "Stat",
      "props": { "label": "Growth", "value": { "$state": "/metrics/growth" } },
      "children": []
    },
    "c3": { "type": "Card", "props": {}, "children": ["s3"] },
    "s3": {
      "type": "Stat",
      "props": { "label": "Active customers", "value": { "$state": "/metrics/customers" } },
      "children": []
    },
    "btn": {
      "type": "Button",
      "props": { "label": "Ask for Q3 detail", "variant": "primary" },
      "children": [],
      "on": { "press": { "action": "ask", "params": { "prompt": "Show me the Q3 revenue breakdown." } } }
    }
  }
}
