{
  "name": "mountly",
  "description": "On-demand interactive UI platform. Use your React/Vue/Svelte components with no new component model, modernize legacy pages incrementally, and load rich UI only when users need it.",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "lint": "vp lint",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:stories": "pnpm run test:unit && PLAYWRIGHT_HTML_OPEN=never playwright test \"tests/.*\\\\.story\\\\.spec\\\\.ts\"",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "quality": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "executable-stories-formatters": "^0.7.9",
    "executable-stories-playwright": "^8.2.6",
    "executable-stories-vitest": "^8.1.10",
    "serve": "^14.2.6",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
