{
  "name": "mountly",
  "description": "On-demand interactive UI platform. Use your React/Vue/Svelte components with no new component model, modernize legacy pages incrementally, and load rich UI only when users need it.",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "lint": "vp lint",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:stories": "pnpm run test:unit && PLAYWRIGHT_HTML_OPEN=never playwright test \"tests/.*\\\\.story\\\\.spec\\\\.ts\"",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "quality": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish",
    "test:e2e:critical": "PLAYWRIGHT_HTML_OPEN=never playwright test \"tests/svelte-adapter.spec.ts\" \"tests/vue-adapter.spec.ts\" \"tests/island.spec.ts\" \"tests/loader-css.spec.ts\" \"tests/host-bootstrap.spec.ts\""
    ,
    "test:mcp:unit": "vitest run tests/mcp-*.story.test.ts",
    "test:mcp:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test \"tests/bridge-pure-ui-libraries.spec.ts\" \"tests/mcp-demo-preview.story.spec.ts\"",
    "test:mcp:verify": "pnpm run test:mcp:unit && pnpm run test:mcp:e2e",
    "test:mcp:demo": "pnpm --filter mcp-app-demo verify"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vue/test-utils": "^2.4.11",
    "executable-stories-formatters": "^0.11.3",
    "executable-stories-playwright": "^8.4.4",
    "executable-stories-vitest": "^8.1.20",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serve": "^14.2.6",
    "svelte": "^5.56.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.6",
    "vue": "^3.5.35",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.7",
      "react-dom": "^19.2.7"
    }
  }
}
