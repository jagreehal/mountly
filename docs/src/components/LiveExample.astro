---
import { exampleUrl } from "../lib/example-urls";

interface Props {
  path: string;
  title?: string;
  height?: string;
}

const { path, title, height = "480px" } = Astro.props;
const src = exampleUrl(path);
---

<div class="live-example not-content">
  {
    title && (
      <p class="live-example-header">
        <a href={src} target="_blank" rel="noopener noreferrer">
          {title} — open in new tab
        </a>
      </p>
    )
  }
  <iframe
    src={src}
    title={title ?? "Live example"}
    loading="lazy"
    style={`height: ${height}; width: 100%; border: 1px solid var(--sl-color-gray-5); border-radius: 8px;`}
  />
</div>

<style>
  .live-example {
    margin: 1.5rem 0;
  }
  .live-example-header {
    margin: 0 0 0.5rem;
    font-size: var(--sl-text-sm);
  }
</style>
