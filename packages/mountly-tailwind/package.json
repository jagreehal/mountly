{
  "name": "mountly-tailwind",
  "version": "0.1.4",
  "description": "Design tokens and Tailwind v4 preset for mountly widgets",
  "homepage": "https://github.com/jagreehal/mountly/tree/main/packages/mountly-tailwind#readme",
  "bugs": {
    "url": "https://github.com/jagreehal/mountly/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/mountly",
    "directory": "packages/mountly-tailwind"
  },
  "style": "./dist/index.css",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./tokens": "./dist/tokens.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "typecheck": "echo 'no TS in this package' && exit 0",
    "dev": "node scripts/build.js --watch",
    "prepack": "rm -f LICENSE && cp ../../LICENSE LICENSE",
    "postpack": "rm -f LICENSE && ln -s ../../LICENSE LICENSE"
  },
  "dependencies": {
    "tailwindcss": "^4.3.1"
  }
}
