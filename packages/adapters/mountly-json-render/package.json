{
  "name": "mountly-json-render",
  "version": "0.1.0",
  "description": "Generative UI for mountly: render @json-render specs as MCP Apps widgets, with the agent-action bridge. createGenerativeWidget + generateSpec.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/mountly",
    "directory": "packages/adapters/mountly-json-render"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "ai": "^6.0.0",
    "mountly": "^0.2.2",
    "mountly-mcp": "workspace:^",
    "mountly-mcp-react": "workspace:^",
    "mountly-react": "^1.0.1",
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@types/react": "^19.2.17",
    "ai": "6.0.194",
    "mountly": "^0.2.2",
    "mountly-mcp": "workspace:^",
    "mountly-mcp-react": "workspace:^",
    "mountly-react": "workspace:^",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
