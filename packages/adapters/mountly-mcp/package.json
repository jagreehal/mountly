{
  "name": "mountly-mcp",
  "version": "0.0.0",
  "description": "Publish a Mountly widget as an MCP Apps ui:// resource (SEP-1865).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/mountly",
    "directory": "packages/adapters/mountly-mcp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./build": {
      "import": "./dist/build/index.js",
      "types": "./dist/build/index.d.ts"
    },
    "./bridge": {
      "import": "./dist/bridge/index.js",
      "types": "./dist/bridge/index.d.ts"
    },
    "./bridge/iframe-entry.js": "./dist/bridge/iframe-entry.js",
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./json-render": {
      "import": "./dist/json-render/index.js",
      "types": "./dist/json-render/index.d.ts"
    },
    "./json-render/server": {
      "import": "./dist/json-render/server.js",
      "types": "./dist/json-render/server.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4"
  },
  "devDependencies": {
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ai": "6.0.208",
    "jsdom": "^29.1.1",
    "mountly": "^0.2.2",
    "mountly-react": "workspace:^",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.207",
    "mountly": "^0.2.2",
    "mountly-react": "^1.0.1",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@json-render/core": {
      "optional": true
    },
    "@json-render/react": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "mountly-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
