{
  "name": "mountly",
  "version": "0.2.3",
  "homepage": "https://github.com/jagreehal/mountly/tree/main/packages/mountly#readme",
  "bugs": {
    "url": "https://github.com/jagreehal/mountly/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/mountly",
    "directory": "packages/mountly"
  },
  "bin": {
    "mountly": "./cli/index.js"
  },
  "files": [
    "dist",
    "cli"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/host-entry.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./triggers": {
      "import": "./dist/triggers.js",
      "types": "./dist/triggers.d.ts"
    },
    "./gestures": {
      "import": "./dist/gestures.js",
      "types": "./dist/gestures.d.ts"
    },
    "./attach": {
      "import": "./dist/attach.js",
      "types": "./dist/attach.d.ts"
    },
    "./elements": {
      "import": "./dist/elements.js",
      "types": "./dist/elements.d.ts"
    },
    "./island": {
      "import": "./dist/island.js",
      "types": "./dist/island.d.ts"
    },
    "./host": {
      "import": "./dist/host.js",
      "types": "./dist/host.d.ts"
    },
    "./host/auto": {
      "import": "./dist/host-entry.js",
      "types": "./dist/host-entry.d.ts"
    },
    "./bundle": {
      "import": "./dist/bundle.js",
      "types": "./dist/bundle.d.ts"
    },
    "./cache": {
      "import": "./dist/cache.js",
      "types": "./dist/cache.d.ts"
    },
    "./mount": {
      "import": "./dist/mount.js",
      "types": "./dist/mount.d.ts"
    },
    "./shadow": {
      "import": "./dist/shadow.js",
      "types": "./dist/shadow.d.ts"
    },
    "./assets": {
      "import": "./dist/assets.js",
      "types": "./dist/assets.d.ts"
    },
    "./adapter": {
      "import": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    },
    "./analytics": {
      "import": "./dist/analytics.js",
      "types": "./dist/analytics.d.ts"
    },
    "./prefetch": {
      "import": "./dist/prefetch.js",
      "types": "./dist/prefetch.d.ts"
    },
    "./devtools": {
      "import": "./dist/devtools.js",
      "types": "./dist/devtools.d.ts"
    },
    "./overlays": {
      "import": "./dist/positioning.js",
      "types": "./dist/positioning.d.ts"
    },
    "./data": {
      "import": "./dist/data-source.js",
      "types": "./dist/data-source.d.ts"
    },
    "./url": {
      "import": "./dist/url-state.js",
      "types": "./dist/url-state.d.ts"
    },
    "./bus": {
      "import": "./dist/bus.js",
      "types": "./dist/bus.d.ts"
    },
    "./contracts": {
      "import": "./dist/contracts.js",
      "types": "./dist/contracts.d.ts"
    },
    "./test": {
      "import": "./dist/test-utils.js",
      "types": "./dist/test-utils.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepack": "rm -f README.md LICENSE && cp ../../README.md README.md && cp ../../LICENSE LICENSE",
    "postpack": "rm -f README.md LICENSE && ln -s ../../README.md README.md && ln -s ../../LICENSE LICENSE"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
