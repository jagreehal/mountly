{
  "name": "mountly",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagreehal/mountly",
    "directory": "packages/mountly"
  },
  "bugs": {
    "url": "https://github.com/jagreehal/mountly/issues"
  },
  "homepage": "https://github.com/jagreehal/mountly/tree/main/packages/mountly#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "cli"],
  "bin": {
    "mountly": "./cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./analytics": {
      "import": "./dist/analytics-entry.js",
      "types": "./dist/analytics-entry.d.ts"
    },
    "./prefetch": {
      "import": "./dist/prefetch-entry.js",
      "types": "./dist/prefetch-entry.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins-entry.js",
      "types": "./dist/plugins-entry.d.ts"
    },
    "./devtools": {
      "import": "./dist/devtools-entry.js",
      "types": "./dist/devtools-entry.d.ts"
    },
    "./overlays": {
      "import": "./dist/overlays-entry.js",
      "types": "./dist/overlays-entry.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime-entry.js",
      "types": "./dist/runtime-entry.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepack": "rm -f README.md LICENSE && cp ../../README.md README.md && cp ../../LICENSE LICENSE",
    "postpack": "rm -f README.md LICENSE && ln -s ../../README.md README.md && ln -s ../../LICENSE LICENSE"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
